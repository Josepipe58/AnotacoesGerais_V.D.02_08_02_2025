<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--================================================| Diretório de Imagens |==============================================================-->

    <ImageBrush x:Key="Voltar_Imagem" ImageSource="/ExibirDados/Recursos/Imagens/Voltar.png" Stretch="None"/>
    <ImageBrush x:Key="PaginainicialImagem" ImageSource="/ExibirDados/Recursos/Imagens/AnotacoesGerais.png" Stretch="Fill"/>
    <ImageBrush x:Key="Logotipo_Imagem" ImageSource="/ExibirDados/Recursos/Imagens/MeuLogotipo.png" Stretch="Fill"/>

    <!--=================================================| MenuLateral |=================================================-->

    <DataTemplate x:Key="MenuLateral">

        <Border CornerRadius="10" Grid.Column="0" Background="#FF021507" Margin="5 20 5 20">


            <StackPanel Margin="0,10,0,0">

                <!--| Logo |-->
                <StackPanel Orientation="Horizontal" Height="50" Margin="15,25,0,20">

                    <TextBlock Text="GERENCIAR DADOS" Foreground="#FFFBF9F9"
                           FontSize="20" FontFamily="Montserrat" FontWeight="Medium" Margin="40,0,0,0"
                           VerticalAlignment="Center" HorizontalAlignment="Left" Width="NaN" />

                    <TextBlock Text="{Binding DataAtual}" Foreground="#FFFBF9F9"
                           FontSize="20" FontFamily="Montserrat" FontWeight="Medium" Margin="10,0,0,0"
                           VerticalAlignment="Center" Background="{x:Null}" HorizontalAlignment="Left" Width="NaN" />
                </StackPanel>
                <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,0">
                    <ItemsControl ItemsSource="{Binding SourceCollection}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="280" Margin="0" Height="100">
                                    <Button Content="{Binding NomeDoMenu}" Width="280" Style="{StaticResource BtnRetangularVerdeEscuro}"
                                            CommandParameter="{Binding NomeDoMenu}" Command="{Binding DataContext.ComandoMenuLateral, 
                                            RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}, Mode=FindAncestor}}" Height="60"/>                                    
                                </StackPanel>                                
                                <!--<Grid Margin="10, 0, 10, 0">
                                    <StackPanel Orientation="Horizontal"  >

                                        <RadioButton Content="{Binding NomeDoMenu}" Tag="{Binding ImagemDoMenu}"                                                     
                                                 CommandParameter="{Binding NomeDoMenu}"
                                                 Command="{Binding RelativeSource={RelativeSource FindAncestor, 
                                                 AncestorType={x:Type ItemsControl}}, Path=DataContext.ComandoMenuLateral}"
                                                 Style="{StaticResource RbtnTransparente}"                                                                                                               
                                                 GroupName="MenuGroup" Width="280"/>
                                    </StackPanel>
                                </Grid>-->                                
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>                    
                </Grid>
                <Grid Grid.Row="4" Grid.Column="1" Margin="0,-60,0,0" Background="{DynamicResource Logotipo_Imagem}" Width="370" Height="370"/>
            </StackPanel>
        </Border>
    </DataTemplate>

    <!--================================================| CalendarioDatePicker |==============================================================-->

    <Style x:Key="CalendarioDatePicker" TargetType="{x:Type DatePicker}">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="SelectedDateFormat" Value="Short"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DatePicker}">
                    <Border BorderThickness="1" Background="#FFECE7E7" Height="30" Width="205">
                        <Grid x:Name="PART_Root" HorizontalAlignment="Center" VerticalAlignment="Stretch" 
                              Background="#FFF5EEEE">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PART_Button" Grid.Column="1" HorizontalAlignment="Center" Margin="0,0,0,0" Grid.Row="0" 
                                    VerticalAlignment="Center" Width="30" Background="#FFF7F6F6" FontSize="14" Content="D" 
                                    Foreground="Black" BorderBrush="#FFF3EEEE" Height="35"/>
                            <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0" HorizontalContentAlignment="Stretch" 
                                               Grid.Row="0" VerticalContentAlignment="Stretch" Foreground="#FFFDFDFD" 
                                               Background="#FF070BF3" Padding="0 0 0 0" Width="NaN"/>
                            <Grid x:Name="PART_DisabledVisual" Grid.ColumnSpan="1" Grid.Column="0" 
                                  Opacity="0" Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" 
                                       PlacementTarget="{Binding ElementName=PART_TextBox}" StaysOpen="True"/>
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--========================================================| TextBoxVerde |==============================================================-->

    <Style x:Key="TextBoxVerde" TargetType="{x:Type TextBox}">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Background" Value="#FF091F0B"/>
        <Setter Property="Padding" Value="10,2,0,0" />
        <Setter Property="Height" Value="30"/>
        <Setter Property="Width" Value="190"/>
        <Setter Property="Margin" Value="0,10,0,10" />
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Top"/>

        <!--|________________________| Essa propriedade é do Ponto de Inserção |__________________________________|-->

        <Setter Property="CaretBrush" Value="White" />

        <!--|______________________________________| Corner Radius |_______________________________________________|-->

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border x:Name="border" CornerRadius="6" BorderThickness="2" 
                            Background="{TemplateBinding Background}" BorderBrush="#FFF5EFEF">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" 
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

