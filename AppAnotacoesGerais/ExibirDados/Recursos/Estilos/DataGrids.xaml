<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--====================================| DtgCabecalhoVerdeEscuro (Cor Verde) dos relatórios |============================================-->
    
    <Style x:Key="DtgCabecalhoVerdeEscuro" TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Padding" Value= "10 0 0 7"/>
        <Setter Property="Background" Value= "#FF09320F"/>
        <Setter Property="FontWeight" Value= "Bold"/>
        <Setter Property="BorderThickness" Value= "0,0,0,1"/>
        <Setter Property="BorderBrush" Value= "#FFE4E4EE"/>
        <Setter Property="Foreground" Value= "#FFE4E4EE"/>
        <Setter Property="FontWeight" Value= "Bold"/>
        <Setter Property="Height" Value= "30"/>
    </Style>
    
    <!--==================================================| DtgCabecalhoAmarelo |=============================================================-->
    <Style x:Key="DtgCabecalhoAmarelo" TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value= "#FFFFF300"/>
        <Setter Property="FontSize" Value= "18"/>
        <Setter Property="FontWeight" Value= "Bold"/>
        <Setter Property="BorderThickness" Value= "1,1,0,1"/>
        <Setter Property="BorderBrush" Value= "Blue"/>
        <Setter Property="Foreground" Value= "Blue"/>
        <Setter Property="FontWeight" Value= "Bold"/>
        <Setter Property="Padding" Value= "20 0 0 4"/>
        <Setter Property="Margin" Value= "5 0 0 0"/>
    </Style>
    
    <!--====================================| DtgDadosCorDaLinhaBisqueWhite (Cor Bisque e Branca) DtgDados |==================================-->

    <Style x:Key="DtgDadosCorDaLinhaBisqueWhite" TargetType="{x:Type DataGrid}">
        <Setter Property="FontSize" Value= "14"/>
        <Setter Property="Foreground" Value="#FF0E1AD2"/>
        <Setter Property="FontWeight" Value= "Bold"/>
        <Setter Property="Background" Value= "#FF11E4E4"/>
        <Setter Property="Cursor" Value= "Hand"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="AlternationCount" Value="2"/>
        <Setter Property="RowBackground" Value="Bisque"/>
        <Setter Property="AlternatingRowBackground" Value="White"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#FF0E1AD2"/>
        <Setter Property="VerticalGridLinesBrush" Value="#FF0E1AD2"/>
        <Setter Property="SelectedIndex" Value="-1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ColumnHeaderStyle" Value="{DynamicResource DtgCabecalhoAmarelo}"/>
    </Style>
    
    <!--====================================| DtgEditorDeTextoInterno |==================================-->

    <Style x:Key="DtgEditorDeTextoInterno" TargetType="{x:Type DataGrid}">
        <Setter Property="FontSize" Value= "14"/>
        <Setter Property="Foreground" Value="#FF0E1AD2"/>
        <Setter Property="FontWeight" Value= "Bold"/>
        <Setter Property="Background" Value= "#FF11E4E4"/>
        <Setter Property="Cursor" Value= "Hand"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="AlternationCount" Value="2"/>
        <Setter Property="RowBackground" Value="Bisque"/>
        <Setter Property="AlternatingRowBackground" Value="White"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#FF0E1AD2"/>
        <Setter Property="VerticalGridLinesBrush" Value="#FF0E1AD2"/>
        <Setter Property="SelectedIndex" Value="-1"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="IsReadOnly" Value="False"/>
        <Setter Property="ColumnHeaderStyle" Value="{DynamicResource DtgCabecalhoVerdeEscuro}"/>
        <Setter Property="RowDetailsTemplate">
            <Setter.Value>
                <DataTemplate>
                    <DockPanel Background="#FF03EECE" IsEnabled="True" Margin="0,10,0,10" Width="1440">

                        <Border  x:Name="Borda04" BorderBrush="Navy" Background="#FFE9EEBA" Margin="10,10,10,10" CornerRadius="25,25,25,25" 
                                 BorderThickness="2,4,3,9">

                            <RichTextBox x:Name="RtbEditor" FontSize="16" FontWeight="Bold" Foreground="White" Background="#FF0D0740" AcceptsTab="True" 
                                         IsReadOnly="False" AcceptsReturn="True" Height="Auto" Width="1380" MinHeight="100" MaxHeight="500" Margin="10,10,10,10" 
                                         Padding="10,10,10,10" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" VerticalAlignment="Top">

                                <FlowDocument PageWidth="{Binding ActualWidth, ElementName=RtbDescricao}">                                   
                                    <Paragraph>
                                        <Run Text="{Binding Descricao}"/>
                                    </Paragraph>
                                </FlowDocument>
                            </RichTextBox>
                        </Border>
                    </DockPanel>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>