<UserControl x:Class="AppAnotacoesGerais.ExibirDados.Views.NomeDescricaoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppAnotacoesGerais.ExibirDados.ViewModels.NomeDescricaoVM"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" xml:lang="pt-BR" d:DesignHeight="1000" d:DesignWidth="1400">

    <UserControl.DataContext>
        <local:NomeDescricaoViewModel/>
    </UserControl.DataContext>
    
    <!--| Grid Principal |-->
    <Grid Background="#FF1C0BE4" Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="347"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!--| Grid Superior |-->
        <Grid Name="GridSuperior" Margin="5,10,5,10">

            <!--| Borda Externa da Grid Superior |-->
            <Border Background="#FF082CEF" BorderBrush="#FF06CDF3" BorderThickness="5" Margin="5,10,5,3" CornerRadius="15">

                <!--| Grid Interna da Borda |-->
                <Grid Background="#FF082CEF" Margin="10,5,10,5">

                    <!--| Seta para voltar ao Submenu de Anotacões Gerais |-->
                    <RadioButton Height="60" Width="66" Style="{StaticResource SetaVoltarMenuAnterior}" Margin="10,-2,0,0" 
                                 Command="{Binding DataContext.ComandoVoltarSubmenuAnotacoesGerais, RelativeSource={RelativeSource 
                                 FindAncestor, AncestorType={x:Type Window}}}" Tag="{DynamicResource SetaVoltarMenuAnterior}" Grid.RowSpan="2"/>

                    <TextBlock Text="Voltar &gt; Para o Submenu de Anotacões Gerais" FontSize="18" FontWeight="Bold" Foreground="#FF06F7F2" 
                               Height="22" Width="398" Margin="80,18,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                    <!--| TeextBlock |-->
                    <TextBlock Text="Nome da Descrição" FontSize="36" FontWeight="Bold" Foreground="#FFF7F7F7" Margin="520,0,0,0" 
                               HorizontalAlignment="Left" VerticalAlignment="Top" Width="335" Height="45"/>

                    <!--| Borda Interna de Cadastrar, Alterar e Excluir |-->
                    <Border Background="#FF0BCEF3" BorderBrush="#FFF1F306" BorderThickness="5" Height="170" Margin="10,0,0,65" 
                            VerticalAlignment="Bottom" CornerRadius="15">

                        <!--| Grid Interna de Cadastrar, Alterar e Excluir |-->
                        <Grid Background="#FF0BCEF3" Width="1205" Margin="20,0,0,10" HorizontalAlignment="Left" Height="145" VerticalAlignment="Bottom">

                            <!--| Rótulos(Label) |-->
                            <Label Content="Cadastrar, Alterar e Excluir Nome da Descrição" FontSize="20" FontWeight="Bold" Foreground="#FF110AEA" 
                                   Height="40" Width="463" Margin="285,-10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                            <Label Content="Id da Categoria" FontSize="16" FontWeight="Bold" Foreground="#FF110AEA" Height="30" Width="165"
                                   Margin="38,20,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>

                            <Label Content="Id da Subcategoria" FontSize="16" FontWeight="Bold" Foreground="#FF110AEA" Height="30" Width="165"
                                   Margin="8,60,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>

                            <Label Content="Id Nome da Descricão" FontSize="16" FontWeight="Bold" Foreground="#FF110AEA" Height="30" Width="200"
                                   Margin="-15,100,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>

                            <Label Content="Nome da Categoria" FontSize="16" FontWeight="Bold" Foreground="#FF110AEA" Height="30" Width="165"
                                   Margin="270,40,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                            <Label Content="Nome da Subcategoria" FontSize="16" FontWeight="Bold" Foreground="#FF110AEA" Height="30" Width="185"
                                   Margin="635,40,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                            <Label Content="Nome da Descrição" FontSize="16" FontWeight="Bold" Foreground="#FF110AEA" Height="30" Width="155"
                                   Margin="280,100,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                            <!--| TextBoxes) |-->
                            <TextBox Text="{Binding NomeDescricaoModel.CategoriaId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="16" Height="30" Width="85" Style="{DynamicResource TxtBrancoEBordaAzul}" Margin="160,20,0,0"
                                     IsReadOnly="True"/>

                            <TextBox Text="{Binding NomeDescricaoModel.SubcategoriaId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="16" Height="30" Width="85" Style="{DynamicResource TxtBrancoEBordaAzul}" Margin="160,60,0,0" 
                                     IsReadOnly="True"/>

                            <TextBox Text="{Binding NomeDescricaoModel.Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                     FontSize="16" Height="30" Width="85" Style="{DynamicResource TxtBrancoEBordaAzul}" Margin="160,100,0,0" 
                                     IsReadOnly="True"/>

                            <TextBox Text="{Binding NomeDescricaoModel.NomeDaDescricao, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                     FontSize="16" Height="30" Width="325" Style="{DynamicResource TxtBrancoEBordaAzul}" Margin="435,100,0,0"/>

                            <!--| ComboBoxes |-->
                            <ComboBox Height="40" Width="200" Style="{DynamicResource ComboBoxAzulMarinho}" Margin="420,35,0,0" 
                                      DisplayMemberPath="NomeCategoria" SelectedValuePath="Id" ItemsSource="{Binding CategoriaModel.ListaDeCategorias}"
                                      SelectedValue="{Binding NomeDescricaoModel.CategoriaId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedItem="{Binding CategoriaSelecionada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedIndex="0"/>

                            <ComboBox Height="40" Width="310" Style="{DynamicResource ComboBoxAzulMarinho}" Margin="820,35,0,0" 
                                      DisplayMemberPath="NomeSubcategoria" SelectedValuePath="Id" ItemsSource="{Binding SubcategoriaModel.ListaDeSubcategorias}"                              
                                      SelectedValue="{Binding NomeDescricaoModel.SubcategoriaId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedIndex="{Binding SubcategoriaModel.IndiceSelecionadoSubcategoria, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <!--| Pesquisar Subcategorias|-->
                            <Grid Margin="770,70,-15,0" Height="80" VerticalAlignment="Top">

                                <TextBox x:Name="TxtPesquisar" Style="{StaticResource PesquisarTextBox}" Width="250" Margin="0,28,0,0" 
                                         Text="{Binding TextoPesquisa, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         VerticalAlignment="Top"/>

                                <TextBlock x:Name="TxbPesquisar" Text="Pesquisar Nome da Descrição" Style="{StaticResource PesquisarTextBlock}" 
                                           Margin="0,28,0,0" VerticalAlignment="Top" Width="250"/>

                                <Button Content="Limpar" FontSize="18" Height="45" Width="160" Style="{DynamicResource BtnRetangularVerdeEscuro}" 
                                        Command="{Binding ComandoAtualizarNomeDescricao}"
                                        Margin="235,10,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!--| Botões) |-->
                    <Button Content="Adicionar" FontSize="16" Width="140" Style="{StaticResource BtnAzulEscuroEAzulClaro}"
                            Command="{Binding ComandoAdicionarNomeDescricao}" Margin="30,240,0,0"/>

                    <Button Content="Editar" FontSize="16" Width="140" Style="{DynamicResource BtnAzulEscuroEAzulClaro}"
                            Command="{Binding ComandoEditarNomeDescricao}" Margin="200,240,0,0"/>

                    <Button Content="Excluir" FontSize="16" Width="140" Style="{DynamicResource BtnAzulEscuroEAzulClaro}" 
                            Command="{Binding ComandoExcluirNomeDescricao}" Margin="370,240,0,0"/>

                    <Button Content="Atualizar" FontSize="16" Width="140" Style="{DynamicResource BtnAzulEscuroEAzulClaro}"
                            Command="{Binding ComandoAtualizarNomeDescricao}" Margin="540,240,0,0"/>
                </Grid>
            </Border>
        </Grid>
        <!--| DataGrid de DtgDados |-->
        <DataGrid x:Name="DtgDados" Style="{DynamicResource DtgDadosCorDaLinhaBisqueWhite}" Margin="5,0,5,5" 
                  ItemsSource="{Binding ListaDoNomeDescricao}" 
                  ColumnHeaderStyle="{DynamicResource DtgCabecalhoAmarelo}" IsReadOnly="True" Grid.Row="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Código" Binding="{Binding CategoriaId, StringFormat=\{0:D4\}}" Width="100"/>
                <DataGridTextColumn Header="Nome da Categoria" Binding="{Binding NomeCategoria}" Width="250"/>
                <DataGridTextColumn Header="Código" Binding="{Binding SubcategoriaId, StringFormat=\{0:D4\}}" Width="100"/>
                <DataGridTextColumn Header="Nome da Subcategoria" Binding="{Binding NomeSubcategoria}" Width="350"/>
                <DataGridTextColumn Header="Código" Binding="{Binding Id, StringFormat=\{0:D4\}}" Width="100"/>
                <DataGridTextColumn Header="Nome da Descrição" Binding="{Binding NomeDaDescricao}" Width="400"/>
            </DataGrid.Columns>
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="MouseDoubleClick">
                    <b:InvokeCommandAction Command="{Binding ComandoDuploClickNomeDescricao}" 
                                           CommandParameter="{Binding SelectedItem, ElementName=DtgDados}" />
                </b:EventTrigger>
            </b:Interaction.Triggers>
        </DataGrid>
    </Grid>
</UserControl>
